# GEMINI_API_KEY: Used for optional auto-titled chats (Gemini). Injected at build time for the browser bundle.
GEMINI_API_KEY=""

# PORT: HTTP port for `npm run dev` (Express + Vite). Defaults to 3000 if unset.
# PORT=3002

# DEEPSEEK_API_KEY: Used only on the dev/prod Node server — never sent to the browser. Required for chat streaming.
# Copy to .env.local (recommended) or .env; server loads .env then .env.local (local overrides).
DEEPSEEK_API_KEY=""

# APP_URL: The URL where this applet is hosted (optional).
APP_URL="MY_APP_URL"
